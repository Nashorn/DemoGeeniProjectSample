            "content-length": "4797",
            "content-type": "text/html; charset=UTF-8",
            "etag": "W/\"2028869-4797-2026-06-16T11:57:56.656Z\"",
            "last-modified": "Tue, 16 Jun 2026 11:57:56 GMT"
          },
          "content": {
            "size": 4797,
            "mimeType": "text/html; charset=UTF-8",
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n\n    <head>\n        <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n        <title>Arc Engine : Drag Drop</title>\n        <!-- <script src=\"https://cdn.jsdelivr.net/gh/Nashorn/od-cocoon@latest/framework.src.js\" namespace=\"ui.screens.ShadowDomDemo\" charset=\"utf-8\"></script> -->\n         <!-- <link rel=\"preload\" as=\"style\" href=\"http://127.0.0.1:8080//src/ui/screens/ShadowDomDemo/shared.css\" onload=\"this.rel='stylesheet'\"> -->\n        <!-- <script \n            src=\"../node_modules/od-cocoon/framework.src.js\" \n            charset=\"utf-8\"\n            data-kernel\n            data-rootpath=\"../\"\n            data-namespace=\"ui.screens.ShadowDomDemo\"\n            data-adopted-stylesheet=\"shared.css\"\n            data-src-path=\"/src/\"\n            data-controller=\"index.js\"\n        ></script> -->\n        <script src=\"../node_modules/od-cocoon/framework.src.js\" charset=\"utf-8\"></script>\n        <script>\n            Config.FILENAME = \"index.js\"\n            Config.ROOTPATH = \"../\"\n            Config.CSSFILENAME = \"shared.css\";\n        </script>\n        <script>\n            (function createMemoryBackedStylesheets() {\n                function createMemoryStyle(id, rules) {\n                    const style = document.createElement(\"style\");\n                    style.id = id;\n                    style.setAttribute(\"data-memory-backed-test\", \"true\");\n                    document.head.appendChild(style);\n\n                    rules.forEach(rule => {\n                        try {\n                            style.sheet.insertRule(rule, style.sheet.cssRules.length);\n                        } catch (error) {\n                            console.warn(\"Unable to insert memory stylesheet test rule\", rule, error);\n                        }\n                    });\n                }\n\n                createMemoryStyle(\"memory-backed-style-a\", [\n                    \".memory-backed-test { border: 2px solid #d24b4b; padding: 12px; margin: 16px 0; background: #fff7d6; color: #222; font: 14px/1.4 system-ui, sans-serif; }\",\n                    \".memory-backed-test strong { color: #7a2f8f; }\",\n                    \"@media (min-width: 700px) { .memory-backed-test { max-width: 520px; } }\"\n                ]);\n\n                createMemoryStyle(\"memory-backed-style-b\", [\n                    \"@keyframes memory-backed-pulse { from { box-shadow: 0 0 0 0 rgba(210, 75, 75, 0.55); } to { box-shadow: 0 0 0 8px rgba(210, 75, 75, 0); } }\",\n                    \".memory-backed-test::after { content: ' memory stylesheet active'; display: block; margin-top: 6px; font-size: 12px; color: #555; }\",\n                    \".memory-backed-test { animation: memory-backed-pulse 1.8s ease-out infinite alternate; }\"\n                ]);\n\n                const memoryBackedCount = Array.from(document.styleSheets).filter(sheet =>\n                    sheet.ownerNode instanceof HTMLStyleElement &&\n                    sheet.cssRules.length &&\n                    !sheet.ownerNode.textContent\n                ).length;\n                console.log(\"[Arc2D demo] memory-backed stylesheet fixtures ready:\", memoryBackedCount);\n            })();\n        </script>\n        <!-- <link rel=\"stylesheet\" href=\"index.css\" id=\"style-test\"> -->\n        <!-- <style>\n            :not(:defined) { \n                display: none;\n            }\n        </style> -->\n    </head>\n\n    <body namespace=\"ui.screens.ShadowDomDemo\">\n        <!-- <message-bar-extended-child>\n            <h3>Extended Child Header</h3>\n        </message-bar-extended-child> -->\n        <!-- <message-bar>\n            <h3>H3 Header XXXXXXXXX </h3>\n            <%= await this.hello() %>\n        </message-bar> -->\n        \n\n        <div class=\"memory-backed-test\">\n            <strong>Memory-backed stylesheet fixture:</strong>\n            these styles come from empty style owner nodes populated through CSSOM insertRule().\n        </div>\n\n        <message-bar>\n            <template shadowrootmode=\"open\">\n                <message-bar-extended>\n                    <template shadowrootmode=\"open\">\n                        <message-bar-extended-child>\n                            <template shadowrootmode=\"open\">\n                                <h3>H3 Header XXXXXXXXX </h3>\n                                <%= await this.hello() %>\n                            </template>\n                        </message-bar-extended-child>\n                    </template>\n                </message-bar-extended>\n            </template>\n        </message-bar>\n\n        <!-- <message-bar-extended>\n                <h3>H3 Header XXXXXXXXX </h3>\n                <%= await this.hello() %>\n        </message-bar-extended> -->\n    </body>\n    \n</html>\n",
            "encoding": null
          }
        },
