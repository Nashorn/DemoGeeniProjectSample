        "request": {
          "method": "GET",
          "url": "http://127.0.0.1:8083/src/system/drivers/templating/TemplateLiterals/driver.js",
          "headers": {
            "Accept": "*/*",
            "Accept-Encoding": "gzip, deflate, br, zstd",
