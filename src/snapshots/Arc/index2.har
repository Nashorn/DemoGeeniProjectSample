          "content": {
            "size": 1192,
            "mimeType": "application/javascript",
            "text": "import 'ui.components.MessageBarExtended';\n\nnamespace `ui.components` (\n\tclass MessageBarExtendedChild extends ui.components.MessageBarExtended  {\n\t\tstatic is = \"message-bar-extended-child\";\n\n\t\tconstructor(el,options) {\n            super(el,options);\n        }\n\t\n\t\tasync onConnected() {\n\t\t\tawait super.onConnected();\n\t\t\tthis.on(\"click\", e=> this.onClick(e), false, \"h3\")\n\t\t\tconsole.log(\"dsd\", [this.hasDSD, this])\n\t\t}\n\n\t\tonClick(e) {\n\t\t\tconsole.log(e.matchedTarget)\n\t\t}\n\n\t\thasOwnTemplate() {\n            return true\n        }\n\n\t\t// inShadow() {\n\t\t// \treturn false\n\t\t// }\n\n\t\t// attachShadow() {\n\t\t// \treturn false\n\t\t// }\n\n\t\t// attachInternals() {\n\t\t// \tdebugger\n\t\t// \treturn false\n\t\t// }\n\n\t\t// hasOwnTemplate() {\n\t\t// \treturn false\n\t\t// }\n\n\t\t// template = () => \n\t\t// `\n\t\t// \t<template>\n\t\t// \t\tMessage Bar Inner template\n\t\t// \t\t<slot></slot>\n\t\t// \t</template>\n\t\t// `\n\t}\n)",
            "encoding": null
