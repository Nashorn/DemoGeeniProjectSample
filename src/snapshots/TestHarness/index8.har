            "last-modified": "Sun, 12 Jul 2026 13:36:40 GMT"
          },
          "content": {
            "size": 27224,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Acme Metrics — Dashboard (iframe selector harness)</title>\n<script\n    src=\"../../node_modules/od-cocoon/framework.src.js\"\n    charset=\"utf-8\"\n    data-kernel\n    data-rootpath=\"../../\"\n    data-namespace=\"ui.screens.IframeSelectorHarness\"\n    data-src-path=\"/src/\"\n    data-controller=\"index.js\"\n></script>\n<style>\n    :root {\n        --bg: #f4f6fa;\n        --panel: #ffffff;\n        --ink: #1c2333;\n        --muted: #6b7487;\n        --accent: #3b6ff0;\n        --accent-ink: #ffffff;\n        --line: #e3e7ef;\n        --ok: #2e9e5b;\n        --warn: #d98324;\n    }\n    * { box-sizing: border-box; }\n    body {\n        margin: 0; background: var(--bg); color: var(--ink);\n        font: 14px/1.5 -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n    }\n\n    /* ---------- header ---------- */\n    header.app-header {\n        display: flex; align-items: center; gap: 24px;\n        background: #101828; color: #fff; padding: 0 20px; height: 56px;\n        position: sticky; top: 0; z-index: 100;\n    }\n    .brand { font-weight: 700; letter-spacing: .3px; }\n    .brand em { color: #7ea2ff; font-style: normal; }\n    nav.top-nav { display: flex; gap: 4px; flex: 1; }\n    nav.top-nav a {\n        color: #c6cbd8; text-decoration: none; padding: 6px 12px; border-radius: 6px;\n    }\n    nav.top-nav a.active, nav.top-nav a:hover { background: #1e2a44; color: #fff; }\n    .user-menu { position: relative; }\n    .user-menu button.avatar {\n        width: 34px; height: 34px; border-radius: 50%; border: 2px solid #3a4a6b;\n        background: #27406e; color: #fff; font-weight: 600; cursor: pointer;\n    }\n    .user-menu .menu {\n        display: none; position: absolute; right: 0; top: 42px; min-width: 180px;\n        background: var(--panel); color: var(--ink); border: 1px solid var(--line);\n        border-radius: 8px; box-shadow: 0 8px 24px rgba(16,24,40,.15); padding: 6px;\n    }\n    .user-menu .menu.open { display: block; }\n    .user-menu .menu a {\n        display: block; padding: 8px 10px; border-radius: 6px; color: var(--ink); text-decoration: none;\n    }\n    .user-menu .menu a:hover { background: #eef2fb; }\n\n    /* ---------- layout ---------- */\n    .shell { display: flex; min-height: calc(100vh - 56px); }\n    aside.sidebar {\n        width: 210px; background: var(--panel); border-right: 1px solid var(--line);\n        padding: 16px 10px;\n    }\n    aside.sidebar h3 {\n        font-size: 11px; text-transform: uppercase; letter-spacing: .8px;\n        color: var(--muted); margin: 14px 8px 6px;\n    }\n    aside.sidebar a {\n        display: block; padding: 7px 10px; border-radius: 6px;\n        color: var(--ink); text-decoration: none;\n    }\n    aside.sidebar a.active { background: #e9effc; color: var(--accent); font-weight: 600; }\n    aside.sidebar a:hover { background: #f0f3f9; }\n    main.content { flex: 1; padding: 22px; max-width: 1200px; }\n\n    h1.page-title { font-size: 20px; margin: 0 0 4px; }\n    p.page-sub { margin: 0 0 20px; color: var(--muted); }\n\n    /* ---------- cards ---------- */\n    .stat-row { display: flex; gap: 14px; margin-bottom: 22px; flex-wrap: wrap; }\n    .stat-card {\n        flex: 1; min-width: 160px; background: var(--panel); border: 1px solid var(--line);\n        border-radius: 10px; padding: 14px 16px;\n    }\n    .stat-card .label { color: var(--muted); font-size: 12px; }\n    .stat-card .value { font-size: 24px; font-weight: 700; margin-top: 2px; }\n    .stat-card .delta { font-size: 12px; }\n    .delta.up { color: var(--ok); }\n    .delta.down { color: #d0453e; }\n\n    section.panel {\n        background: var(--panel); border: 1px solid var(--line); border-radius: 10px;\n        margin-bottom: 22px;\n    }\n    section.panel > .panel-head {\n        display: flex; align-items: center; justify-content: space-between;\n        padding: 12px 16px; border-bottom: 1px solid var(--line);\n    }\n    section.panel > .panel-head h2 { font-size: 15px; margin: 0; }\n    section.panel > .panel-body { padding: 16px; }\n    .hint { color: var(--muted); font-size: 12px; }\n\n    button.btn {\n        background: var(--accent); color: var(--accent-ink); border: 0;\n        padding: 7px 14px; border-radius: 7px; cursor: pointer; font-weight: 600;\n    }\n    button.btn.secondary { background: #eef1f7; color: var(--ink); }\n\n    table.orders { width: 100%; border-collapse: collapse; }\n    table.orders th, table.orders td { text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--line); }\n    table.orders th { color: var(--muted); font-weight: 600; font-size: 12px; }\n    .pill { display: inline-block; padding: 2px 9px; border-radius: 999px; font-size: 12px; font-weight: 600; }\n    .pill.paid { background: #e5f6ec; color: var(--ok); }\n    .pill.pending { background: #fdf0e0; color: var(--warn); }\n\n    iframe.embed {\n        display: block; width: 100%; border: 1px solid var(--line); border-radius: 8px; background: #fff;\n    }\n    #editor { height: 340px; }\n    #ad-banner { height: 90px; }\n    .xorigin-row { display: flex; gap: 14px; }\n    .xorigin-row > div { flex: 1; }\n    #office-map { height: 220px; }\n    #status-page { height: 220px; }\n\n    .team-row { display: flex; gap: 14px; flex-wrap: wrap; }\n\n    /* ---------- modal ---------- */\n    dialog#invite-modal {\n        border: 0; border-radius: 12px; padding: 0; width: 380px;\n        box-shadow: 0 24px 60px rgba(16,24,40,.3);\n    }\n    dialog#invite-modal::backdrop { background: rgba(16,24,40,.45); }\n    dialog#invite-modal .modal-head { padding: 16px 18px 0; }\n    dialog#invite-modal .modal-head h3 { margin: 0; }\n    dialog#invite-modal form { padding: 14px 18px 18px; display: flex; flex-direction: column; gap: 10px; }\n    dialog#invite-modal input, dialog#invite-modal select {\n        padding: 8px 10px; border: 1px solid var(--line); border-radius: 7px; font: inherit;\n    }\n    dialog#invite-modal .modal-actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 4px; }\n\n    footer.app-footer {\n        padding: 18px 22px; color: var(--muted); font-size: 12px;\n        border-top: 1px solid var(--line);\n    }\n\n    /* ---------- harness legend ---------- */\n    section#harness-legend .case { margin-bottom: 10px; }\n    section#harness-legend code {\n        display: block; background: #101828; color: #9fd0ff; padding: 6px 10px;\n        border-radius: 6px; font: 12px/1.6 ui-monospace, Menlo, Consolas, monospace;\n        overflow-x: auto; white-space: nowrap;\n    }\n    section#harness-legend .case b { font-size: 13px; }\n</style>\n</head>\n<body namespace=\"ui.screens.IframeSelectorHarness\">\n\n<header class=\"app-header\">\n    <div class=\"brand\">Acme<em>Metrics</em></div>\n    <nav class=\"top-nav\">\n        <a href=\"#\" class=\"active\">Dashboard</a>\n        <a href=\"#\">Reports</a>\n        <a href=\"#\">Customers</a>\n        <a href=\"#\">Settings</a>\n    </nav>\n    <div class=\"user-menu\">\n        <button class=\"avatar\" id=\"user-menu-btn\" title=\"Account\">JS</button>\n        <div class=\"menu\" id=\"user-menu-dropdown\">\n            <a href=\"#\" id=\"menu-profile\">Profile</a>\n            <a href=\"#\" id=\"menu-billing\">Billing</a>\n            <a href=\"#\" id=\"menu-signout\">Sign out</a>\n        </div>\n    </div>\n</header>\n\n<div class=\"shell\">\n    <aside class=\"sidebar\">\n        <h3>Analytics</h3>\n        <a href=\"#\" class=\"active\" id=\"nav-overview\">Overview</a>\n        <a href=\"#\" id=\"nav-funnels\">Funnels</a>\n        <a href=\"#\" id=\"nav-retention\">Retention</a>\n        <h3>Workspace</h3>\n        <a href=\"#\" id=\"nav-team\">Team</a>\n        <a href=\"#\" id=\"nav-integrations\">Integrations</a>\n    </aside>\n\n    <main class=\"content\">\n        <h1 class=\"page-title\">Overview</h1>\n        <p class=\"page-sub\">Your workspace at a glance — last 30 days.</p>\n\n        <!-- plain-DOM stat cards -->\n        <div class=\"stat-row\" id=\"stats\">\n            <div class=\"stat-card\">\n                <div class=\"label\">Revenue</div>\n                <div class=\"value\">$48,230</div>\n                <div class=\"delta up\">▲ 12.4%</div>\n            </div>\n            <div class=\"stat-card\">\n                <div class=\"label\">Active users</div>\n                <div class=\"value\">9,412</div>\n                <div class=\"delta up\">▲ 3.1%</div>\n            </div>\n            <div class=\"stat-card\">\n                <div class=\"label\">Churn</div>\n                <div class=\"value\">1.9%</div>\n                <div class=\"delta down\">▼ 0.4%</div>\n            </div>\n            <div class=\"stat-card\">\n                <div class=\"label\">Open tickets</div>\n                <div class=\"value\">37</div>\n                <div class=\"delta\">—</div>\n            </div>\n        </div>\n\n        <!-- CASE: shadow DOM (>>>), incl. nested shadow root -->\n        <section class=\"panel\" id=\"team-panel\">\n            <div class=\"panel-head\">\n                <h2>Team</h2>\n                <button class=\"btn\" id=\"invite-btn\">Invite member</button>\n            </div>\n            <div class=\"panel-body\">\n                <div class=\"team-row\">\n                    <user-card name=\"Dana Ito\" role=\"Engineering\" status=\"online\"></user-card>\n                    <user-card name=\"Marcus Webb\" role=\"Design\" status=\"away\"></user-card>\n                    <user-card name=\"Priya Nair\" role=\"Product\" status=\"online\"></user-card>\n                </div>\n                <p class=\"hint\">Cards are shadow-DOM components; the status badge is a <em>nested</em> shadow root.</p>\n            </div>\n        </section>\n\n        <!-- CASE: iframe (::document), containing a shadow component (::document … >>>) and a nested iframe (::document … ::document) -->\n        <section class=\"panel\" id=\"editor-panel\">\n            <div class=\"panel-head\">\n                <h2>Campaign editor</h2>\n                <span class=\"hint\">embedded editor app (same-origin iframe)</span>\n            </div>\n            <div class=\"panel-body\">\n                <iframe class=\"embed\" id=\"editor\" src=\"frames/editor.html\" title=\"Campaign editor\"></iframe>\n            </div>\n        </section>\n\n        <!-- CASE: iframe inside a shadow root (>>> … ::document) -->\n        <section class=\"panel\" id=\"report-panel\">\n            <div class=\"panel-head\">\n                <h2>Weekly report</h2>\n                <span class=\"hint\">iframe hosted INSIDE a shadow root</span>\n            </div>\n            <div class=\"panel-body\">\n                <embedded-report src=\"frames/report.html\"></embedded-report>\n            </div>\n        </section>\n\n        <!-- plain-DOM table -->\n        <section class=\"panel\" id=\"orders-panel\">\n            <div class=\"panel-head\">\n                <h2>Recent orders</h2>\n                <button class=\"btn secondary\" id=\"export-orders\">Export CSV</button>\n            </div>\n            <div class=\"panel-body\">\n                <table class=\"orders\">\n                    <thead>\n                        <tr><th>Order</th><th>Customer</th><th>Amount</th><th>Status</th></tr>\n                    </thead>\n                    <tbody>\n                        <tr><td>#10412</td><td>Northwind Ltd.</td><td>$1,250.00</td><td><span class=\"pill paid\">Paid</span></td></tr>\n                        <tr><td>#10411</td><td>Initech</td><td>$420.00</td><td><span class=\"pill pending\">Pending</span></td></tr>\n                        <tr><td>#10410</td><td>Globex Corp.</td><td>$3,780.00</td><td><span class=\"pill paid\">Paid</span></td></tr>\n                        <tr><td>#10409</td><td>Stark Industries</td><td>$980.00</td><td><span class=\"pill paid\">Paid</span></td></tr>\n                    </tbody>\n                </table>\n            </div>\n        </section>\n\n        <!-- CASE: srcdoc iframe (::document on a document with no URL) -->\n        <section class=\"panel\" id=\"promo-panel\">\n            <div class=\"panel-head\">\n                <h2>Partner promo</h2>\n                <span class=\"hint\">srcdoc iframe — document has no URL</span>\n            </div>\n            <div class=\"panel-body\">\n                <iframe class=\"embed\" id=\"ad-banner\" title=\"Partner promo\" srcdoc=\"\n                    &lt;body style='margin:0;font:13px -apple-system,sans-serif;display:flex;align-items:center;justify-content:space-between;padding:0 18px;height:90px;background:linear-gradient(90deg,#101828,#27406e);color:#fff'&gt;\n                        &lt;div&gt;\n                            &lt;strong id='promo-title'&gt;CloudRelay Pro&lt;/strong&gt;&lt;br&gt;\n                            &lt;span style='color:#b9c6e4'&gt;Ship webhooks 4x faster. 30-day trial.&lt;/span&gt;\n                        &lt;/div&gt;\n                        &lt;button id='promo-cta' style='background:#7ea2ff;border:0;color:#0c1526;font-weight:700;padding:8px 16px;border-radius:7px;cursor:pointer'&gt;Start trial&lt;/button&gt;\n                    &lt;/body&gt;\"></iframe>\n            </div>\n        </section>\n\n        <!-- CASE: iframe nested under THREE shadow roots (>>> >>> >>> … ::document) -->\n        <section class=\"panel\" id=\"support-panel\">\n            <div class=\"panel-head\">\n                <h2>Support</h2>\n                <span class=\"hint\">iframe nested inside 3 levels of shadow roots</span>\n            </div>\n            <div class=\"panel-body\">\n                <support-widget></support-widget>\n            </div>\n        </section>\n\n        <!-- CASE: CROSS-ORIGIN iframes (third-party domains) — ::document must NOT cross -->\n        <section class=\"panel\" id=\"xorigin-panel\">\n            <div class=\"panel-head\">\n                <h2>Office &amp; status</h2>\n                <span class=\"hint\">cross-origin iframes (third-party domains) — boundary is NOT crossable. Note: google.com itself refuses framing (X-Frame-Options: SAMEORIGIN)</span>\n            </div>\n            <div class=\"panel-body\">\n                <!-- Deterministic opaque-origin boundary for the automated suite. -->\n                <iframe id=\"opaque-frame\" sandbox srcdoc=\"<body><p id='private-target'>Private</p></body>\" hidden></iframe>\n                <div class=\"xorigin-row\">\n                    <div>\n                        <p class=\"hint\" style=\"margin-top:0\">HQ location (openstreetmap.org)</p>\n                        <iframe class=\"embed\" id=\"office-map\"\n                            src=\"https://www.openstreetmap.org/export/embed.html?bbox=-122.52%2C37.70%2C-122.35%2C37.83&layer=mapnik\"\n                            title=\"Office location\" loading=\"lazy\"></iframe>\n                    </div>\n                    <div>\n                        <p class=\"hint\" style=\"margin-top:0\">Vendor status page (example.com)</p>\n                        <iframe class=\"embed\" id=\"status-page\"\n                            src=\"https://example.com/\"\n                            title=\"Vendor status\" loading=\"lazy\"></iframe>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- test matrix: expected breadcrumb / selector shapes -->\n        <section class=\"panel\" id=\"harness-legend\">\n            <div class=\"panel-head\"><h2>Harness legend — expected selector shapes</h2></div>\n            <div class=\"panel-body\">\n                <div class=\"case\">\n                    <b>1 — plain DOM</b>\n                    <code>body > div.shell > main > section#orders-panel > div:nth-of-type(2) > table > tbody > tr:nth-of-type(2) > td:nth-of-type(4) > span</code>\n                </div>\n                <div class=\"case\">\n                    <b>2 — shadow root (&gt;&gt;&gt;)</b>\n                    <code>body > div.shell > main > section#team-panel … > user-card:nth-of-type(1) >>> button#msg-btn</code>\n                </div>\n                <div class=\"case\">\n                    <b>3 — nested shadow (&gt;&gt;&gt; &gt;&gt;&gt;)</b>\n                    <code>… > user-card:nth-of-type(2) >>> status-badge >>> span#dot</code>\n                </div>\n                <div class=\"case\">\n                    <b>4 — iframe (::document), component inside it (::document … &gt;&gt;&gt;) — the canonical example</b>\n                    <code>… > section#editor-panel … > iframe#editor ::document body > main > editor-toolbar >>> button.save</code>\n                </div>\n                <div class=\"case\">\n                    <b>5 — nested iframe (::document … ::document)</b>\n                    <code>… > iframe#editor ::document body > main > section#preview-pane > iframe#preview ::document body > article > h1#preview-title</code>\n                </div>\n                <div class=\"case\">\n                    <b>6 — iframe inside shadow root (&gt;&gt;&gt; … ::document)</b>\n                    <code>… > section#report-panel … > embedded-report >>> iframe#report ::document body > section#kpis > div:nth-of-type(1)</code>\n                </div>\n                <div class=\"case\">\n                    <b>7 — srcdoc iframe (::document on a URL-less document)</b>\n                    <code>… > section#promo-panel … > iframe#ad-banner ::document body > button#promo-cta</code>\n                </div>\n                <div class=\"case\">\n                    <b>8 — CROSS-ORIGIN iframes (openstreetmap.org / example.com) — boundary must NOT cross</b>\n                    <code>… > section#xorigin-panel … > iframe#office-map   (deepest pickable node; no ::document — contentDocument is inaccessible)</code>\n                </div>\n                <div class=\"case\">\n                    <b>9 — iframe under THREE shadow roots (&gt;&gt;&gt; &gt;&gt;&gt; &gt;&gt;&gt; … ::document)</b>\n                    <code>… > section#support-panel … > support-widget >>> chat-panel >>> chat-frame >>> iframe#chat ::document html > body > form#composer > button#send-btn</code>\n                </div>\n            </div>\n        </section>\n    </main>\n</div>\n\n<footer class=\"app-footer\">\n    Acme Metrics · iframe/shadow selector test harness · Arc2D demos\n</footer>\n\n<!-- modal for recorder/interaction testing -->\n<dialog id=\"invite-modal\">\n    <div class=\"modal-head\"><h3>Invite a team member</h3></div>\n    <form method=\"dialog\">\n        <input type=\"email\" id=\"invite-email\" placeholder=\"name@company.com\" required>\n        <select id=\"invite-role\">\n            <option value=\"viewer\">Viewer</option>\n            <option value=\"editor\">Editor</option>\n            <option value=\"admin\">Admin</option>\n        </select>\n        <div class=\"modal-actions\">\n            <button class=\"btn secondary\" value=\"cancel\" id=\"invite-cancel\">Cancel</button>\n            <button class=\"btn\" value=\"send\" id=\"invite-send\">Send invite</button>\n        </div>\n    </form>\n</dialog>\n\n<script>\n    // ---------- shadow-DOM components ----------\n\n    // <user-card> — open shadow root; contains a NESTED shadow component <status-badge>.\n    class UserCard extends HTMLElement {\n        connectedCallback() {\n            const root = this.attachShadow({ mode: 'open' });\n            const name = this.getAttribute('name') || 'Unknown';\n            const role = this.getAttribute('role') || '';\n            const status = this.getAttribute('status') || 'offline';\n            root.innerHTML = `\n                <style>\n                    :host { display: block; width: 190px; }\n                    .card {\n                        border: 1px solid #e3e7ef; border-radius: 10px; padding: 12px;\n                        background: #fff; font: 13px/1.45 -apple-system, sans-serif;\n                    }\n                    .who { display: flex; align-items: center; gap: 9px; margin-bottom: 8px; }\n                    .pic {\n                        width: 34px; height: 34px; border-radius: 50%; background: #27406e;\n                        color: #fff; display: flex; align-items: center; justify-content: center;\n                        font-weight: 700; font-size: 12px;\n                    }\n                    .name { font-weight: 600; }\n                    .role { color: #6b7487; font-size: 12px; }\n                    button#msg-btn {\n                        width: 100%; margin-top: 6px; padding: 6px 0; border-radius: 6px;\n                        border: 1px solid #d7ddea; background: #f4f6fb; cursor: pointer; font-weight: 600;\n                    }\n                    button#msg-btn:hover { background: #e9effc; }\n                </style>\n                <div class=\"card\">\n                    <div class=\"who\">\n                        <div class=\"pic\">${name.split(' ').map(w => w[0]).join('')}</div>\n                        <div>\n                            <div class=\"name\">${name}</div>\n                            <div class=\"role\">${role}</div>\n                        </div>\n                    </div>\n                    <status-badge state=\"${status}\"></status-badge>\n                    <button id=\"msg-btn\">Message</button>\n                </div>\n            `;\n        }\n    }\n\n    // <status-badge> — the nested shadow root inside <user-card>'s shadow tree.\n    class StatusBadge extends HTMLElement {\n        connectedCallback() {\n            const root = this.attachShadow({ mode: 'open' });\n            const state = this.getAttribute('state') || 'offline';\n            const colors = { online: '#2e9e5b', away: '#d98324', offline: '#98a1b3' };\n            root.innerHTML = `\n                <style>\n                    .badge { display: inline-flex; align-items: center; gap: 6px; font: 12px -apple-system, sans-serif; color: #4b5468; }\n                    #dot { width: 9px; height: 9px; border-radius: 50%; background: ${colors[state] || colors.offline}; }\n                </style>\n                <span class=\"badge\"><span id=\"dot\"></span><span id=\"state-label\">${state}</span></span>\n            `;\n        }\n    }\n\n    // <embedded-report> — an iframe living INSIDE a shadow root (>>> … ::document case).\n    class EmbeddedReport extends HTMLElement {\n        connectedCallback() {\n            const root = this.attachShadow({ mode: 'open' });\n            const src = this.getAttribute('src') || '';\n            root.innerHTML = `\n                <style>\n                    :host { display: block; }\n                    .frame-chrome { border: 1px solid #e3e7ef; border-radius: 8px; overflow: hidden; }\n                    .frame-bar {\n                        display: flex; align-items: center; gap: 8px; padding: 6px 10px;\n                        background: #f0f3f9; border-bottom: 1px solid #e3e7ef;\n                        font: 12px -apple-system, sans-serif; color: #6b7487;\n                    }\n                    .frame-bar .dot { width: 8px; height: 8px; border-radius: 50%; background: #d0d6e2; }\n                    iframe#report { display: block; width: 100%; height: 230px; border: 0; background: #fff; }\n                </style>\n                <div class=\"frame-chrome\">\n                    <div class=\"frame-bar\">\n                        <span class=\"dot\"></span><span class=\"dot\"></span><span class=\"dot\"></span>\n                        <span>report widget</span>\n                    </div>\n                    <iframe id=\"report\" src=\"${src}\" title=\"Weekly report\"></iframe>\n                </div>\n            `;\n        }\n    }\n\n    // ---------- CASE 9: iframe nested under THREE shadow roots ----------\n    // <support-widget> (shadow L1) > <chat-panel> (shadow L2) > <chat-frame>\n    // (shadow L3) > iframe#chat. Expected boundary chain: >>> >>> >>> … ::document\n\n    class SupportWidget extends HTMLElement {\n        connectedCallback() {\n            const root = this.attachShadow({ mode: 'open' });\n            root.innerHTML = `\n                <style>\n                    :host { display: block; max-width: 460px; }\n                    .widget { border: 1px solid #e3e7ef; border-radius: 10px; background: #fff; }\n                    .widget-head {\n                        display: flex; align-items: center; gap: 8px; padding: 10px 14px;\n                        border-bottom: 1px solid #e3e7ef; font: 600 13px -apple-system, sans-serif;\n                    }\n                    .beacon { width: 9px; height: 9px; border-radius: 50%; background: #2e9e5b; }\n                </style>\n                <div class=\"widget\">\n                    <div class=\"widget-head\"><span class=\"beacon\"></span> Support — we're online</div>\n                    <chat-panel></chat-panel>\n                </div>\n            `;\n        }\n    }\n\n    class ChatPanel extends HTMLElement {\n        connectedCallback() {\n            const root = this.attachShadow({ mode: 'open' });\n            root.innerHTML = `\n                <style>\n                    :host { display: block; }\n                    .panel { padding: 10px 14px; }\n                    .agent-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; font: 12px -apple-system, sans-serif; color: #6b7487; }\n                    .agent-pic {\n                        width: 26px; height: 26px; border-radius: 50%; background: #27406e; color: #fff;\n                        display: inline-flex; align-items: center; justify-content: center; font: 700 11px -apple-system, sans-serif;\n                    }\n                </style>\n                <div class=\"panel\">\n                    <div class=\"agent-row\"><span class=\"agent-pic\">AR</span> Aria from support</div>\n                    <chat-frame></chat-frame>\n                </div>\n            `;\n        }\n    }\n\n    class ChatFrame extends HTMLElement {\n        connectedCallback() {\n            const root = this.attachShadow({ mode: 'open' });\n            root.innerHTML = `\n                <style>\n                    :host { display: block; }\n                    iframe#chat { display: block; width: 100%; height: 240px; border: 1px solid #e3e7ef; border-radius: 8px; background: #fff; }\n                </style>\n                <iframe id=\"chat\" src=\"frames/chat.html\" title=\"Support chat\"></iframe>\n            `;\n        }\n    }\n\n    customElements.define('user-card', UserCard);\n    customElements.define('status-badge', StatusBadge);\n    customElements.define('embedded-report', EmbeddedReport);\n    customElements.define('support-widget', SupportWidget);\n    customElements.define('chat-panel', ChatPanel);\n    customElements.define('chat-frame', ChatFrame);\n\n    // ---------- interactions (dropdown + modal, for recorder tests) ----------\n    const menuBtn = document.getElementById('user-menu-btn');\n    const menu = document.getElementById('user-menu-dropdown');\n    menuBtn.addEventListener('click', (e) => {\n        e.stopPropagation();\n        menu.classList.toggle('open');\n        menuBtn.setAttribute('aria-expanded', menu.classList.contains('open'));\n    });\n    document.addEventListener('click', () => menu.classList.remove('open'));\n\n    const modal = document.getElementById('invite-modal');\n    document.getElementById('invite-btn').addEventListener('click', () => modal.showModal());\n</script>\n\n</body>\n</html>\n",
