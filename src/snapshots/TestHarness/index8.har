          },
          "content": {
            "size": 1629,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Message Preview (iframe level 2 — nested)</title>\n<style>\n    body {\n        margin: 0; padding: 14px 16px; background: #fff; color: #1c2333;\n        font: 13px/1.55 Georgia, \"Times New Roman\", serif;\n    }\n    article { max-width: 420px; }\n    h1#preview-title { font-size: 17px; margin: 0 0 8px; }\n    p { margin: 0 0 10px; }\n    a.cta {\n        display: inline-block; background: #3b6ff0; color: #fff; text-decoration: none;\n        font: 600 12px -apple-system, sans-serif; padding: 8px 16px; border-radius: 6px;\n    }\n    footer { margin-top: 14px; color: #98a1b3; font: 11px -apple-system, sans-serif; }\n</style>\n</head>\n<body>\n    <!-- CASE 5 target: node in the NESTED iframe.\n         Expected: … > iframe#editor ::document body > main > … > iframe#preview ::document body > article > h1#preview-title -->\n    <article>\n        <h1 id=\"preview-title\">July product update 🎉</h1>\n        <p>Hi Dana, here's what shipped in July…</p>\n        <p>We rebuilt the funnel explorer, added CSV exports, and cut dashboard load times in half.</p>\n        <a class=\"cta\" href=\"#\" id=\"preview-cta\">Read the changelog</a>\n        <footer>Sent with AcmeMetrics · <a href=\"#\" id=\"unsub\">Unsubscribe</a></footer>\n    </article>\n</body>\n</html>\n",
            "encoding": null
          }
        },
        "disk": {
