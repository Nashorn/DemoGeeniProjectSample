          "mimeType": "text/html",
          "headers": {
            "Connection": "keep-alive",
            "Date": "Sun, 12 Jul 2026 20:26:14 GMT",
            "Keep-Alive": "timeout=5",
            "accept-ranges": "bytes",
            "cache-control": "max-age=3600",
            "content-length": "4213",
            "content-type": "text/html; charset=UTF-8",
            "etag": "W/\"52623072-4213-2026-07-12T13:35:49.258Z\"",
            "last-modified": "Sun, 12 Jul 2026 13:35:49 GMT"
          },
          "content": {
            "size": 4525,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Campaign Editor (iframe level 1)</title>\n<style>\n    * { box-sizing: border-box; }\n    body {\n        margin: 0; background: #fbfcfe; color: #1c2333;\n        font: 13px/1.5 -apple-system, \"Segoe UI\", Roboto, sans-serif;\n    }\n    main { padding: 12px 14px; }\n    .editor-grid { display: flex; gap: 12px; margin-top: 10px; }\n    section#compose-pane { flex: 1.2; }\n    section#preview-pane { flex: 1; }\n    label { display: block; font-size: 12px; color: #6b7487; margin: 10px 0 3px; }\n    input[type=\"text\"], textarea, select {\n        width: 100%; padding: 7px 9px; border: 1px solid #dde2ec; border-radius: 6px; font: inherit;\n    }\n    textarea { height: 90px; resize: vertical; }\n    h2.pane-title { font-size: 13px; margin: 0 0 4px; color: #4b5468; text-transform: uppercase; letter-spacing: .6px; }\n    iframe#preview {\n        display: block; width: 100%; height: 190px;\n        border: 1px solid #dde2ec; border-radius: 6px; background: #fff;\n    }\n</style>\n</head>\n<body>\n<main>\n    <!-- CASE 4 target: shadow component inside this iframe document.\n         Expected: … > iframe#editor ::document body > main > editor-toolbar >>> button.save -->\n    <editor-toolbar></editor-toolbar>\n\n    <div class=\"editor-grid\">\n        <section id=\"compose-pane\">\n            <h2 class=\"pane-title\">Compose</h2>\n            <label for=\"subject\">Subject line</label>\n            <input type=\"text\" id=\"subject\" value=\"July product update 🎉\">\n            <label for=\"audience\">Audience</label>\n            <select id=\"audience\">\n                <option>All subscribers</option>\n                <option>Trial users</option>\n                <option>Churn risk</option>\n            </select>\n            <label for=\"body-copy\">Body</label>\n            <textarea id=\"body-copy\">Hi {{first_name}}, here's what shipped in July…</textarea>\n        </section>\n\n        <section id=\"preview-pane\">\n            <h2 class=\"pane-title\">Live preview</h2>\n            <!-- CASE 5 target: iframe nested inside this iframe (::document … ::document) -->\n            <iframe id=\"preview\" src=\"preview.html\" title=\"Message preview\"></iframe>\n        </section>\n    </div>\n</main>\n\n<script>\n    // <editor-toolbar> — shadow component INSIDE the iframe document.\n    class EditorToolbar extends HTMLElement {\n        connectedCallback() {\n            const root = this.attachShadow({ mode: 'open' });\n            root.innerHTML = `\n                <style>\n                    :host { display: block; }\n                    .bar {\n                        display: flex; align-items: center; gap: 6px;\n                        background: #fff; border: 1px solid #dde2ec; border-radius: 8px; padding: 6px 8px;\n                    }\n                    .bar .spacer { flex: 1; }\n                    button {\n                        border: 1px solid #d7ddea; background: #f4f6fb; border-radius: 6px;\n                        padding: 5px 11px; cursor: pointer; font: 600 12px -apple-system, sans-serif; color: #1c2333;\n                    }\n                    button:hover { background: #e9effc; }\n                    button.save { background: #3b6ff0; border-color: #3b6ff0; color: #fff; }\n                    button.save:hover { background: #2f5dd4; }\n                </style>\n                <div class=\"bar\">\n                    <button class=\"fmt\" data-cmd=\"bold\" title=\"Bold\"><b>B</b></button>\n                    <button class=\"fmt\" data-cmd=\"italic\" title=\"Italic\"><i>I</i></button>\n                    <button class=\"fmt\" data-cmd=\"link\" title=\"Link\">🔗</button>\n                    <span class=\"spacer\"></span>\n                    <button class=\"preview-btn\">Preview</button>\n                    <button class=\"save\">Save draft</button>\n                </div>\n            `;\n            root.querySelector('button.save').addEventListener('click', () => {\n                root.querySelector('button.save').textContent = 'Saved ✓';\n                setTimeout(() => root.querySelector('button.save').textContent = 'Save draft', 1200);\n            });\n        }\n    }\n    customElements.define('editor-toolbar', EditorToolbar);\n</script>\n</body>\n</html>\n",
            "encoding": null
          }
        },
