        "response": {
          "status": 200,
          "statusText": "OK",
          "mimeType": "text/html",
          "headers": {
            "Connection": "keep-alive",
            "Date": "Sun, 12 Jul 2026 20:26:15 GMT",
            "Keep-Alive": "timeout=5",
            "accept-ranges": "bytes",
            "cache-control": "max-age=3600",
            "content-length": "2685",
            "content-type": "text/html; charset=UTF-8",
            "etag": "W/\"52638500-2685-2026-07-12T13:35:49.258Z\"",
            "last-modified": "Sun, 12 Jul 2026 13:35:49 GMT"
          },
          "content": {
            "size": 2997,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Support Chat (iframe under 3 shadow roots)</title>\n<style>\n    * { box-sizing: border-box; }\n    body {\n        margin: 0; display: flex; flex-direction: column; height: 100vh;\n        background: #fbfcfe; color: #1c2333; font: 13px/1.45 -apple-system, \"Segoe UI\", Roboto, sans-serif;\n    }\n    main#thread { flex: 1; overflow-y: auto; padding: 12px 14px; display: flex; flex-direction: column; gap: 8px; }\n    .msg { max-width: 78%; padding: 8px 11px; border-radius: 12px; }\n    .msg.agent { background: #eef1f7; align-self: flex-start; border-bottom-left-radius: 4px; }\n    .msg.me { background: #3b6ff0; color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; }\n    form#composer {\n        display: flex; gap: 8px; padding: 10px 12px; border-top: 1px solid #e3e7ef; background: #fff;\n    }\n    input#chat-input {\n        flex: 1; padding: 8px 10px; border: 1px solid #dde2ec; border-radius: 7px; font: inherit;\n    }\n    button#send-btn {\n        background: #3b6ff0; color: #fff; border: 0; border-radius: 7px;\n        padding: 8px 16px; font: 600 12px -apple-system, sans-serif; cursor: pointer;\n    }\n    button#send-btn:hover { background: #2f5dd4; }\n</style>\n</head>\n<body>\n    <!-- CASE 9 target: this document sits under support-widget >>> chat-panel >>> chat-frame >>> iframe#chat.\n         Expected: … >>> >>> >>> iframe#chat ::document html > body > form#composer > button#send-btn -->\n    <main id=\"thread\">\n        <div class=\"msg agent\">Hi! I'm Aria — how can I help today?</div>\n        <div class=\"msg me\">My weekly report iframe was blank after capture 🙃</div>\n        <div class=\"msg agent\">Classic. Have you tried recursing into the templates directly?</div>\n    </main>\n    <form id=\"composer\">\n        <input type=\"text\" id=\"chat-input\" placeholder=\"Type a message…\" autocomplete=\"off\">\n        <button type=\"submit\" id=\"send-btn\">Send</button>\n    </form>\n    <script>\n        // Sending appends a message — recordable childList mutation inside a\n        // triple-shadow-nested iframe document.\n        document.getElementById('composer').addEventListener('submit', (e) => {\n            e.preventDefault();\n            const input = document.getElementById('chat-input');\n            const text = input.value.trim();\n            if (!text) return;\n            const div = document.createElement('div');\n            div.className = 'msg me';\n            div.textContent = text;\n            document.getElementById('thread').appendChild(div);\n            input.value = '';\n            div.scrollIntoView({ block: 'nearest' });\n        });\n    </script>\n</body>\n</html>\n",
            "encoding": null
          }
        },
        "disk": {
          "filename": "chat.html",
