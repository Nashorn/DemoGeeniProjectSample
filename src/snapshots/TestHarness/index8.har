          "content": {
            "size": 2775,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Weekly Report (iframe hosted inside a shadow root)</title>\n<style>\n    * { box-sizing: border-box; }\n    body {\n        margin: 0; padding: 12px 14px; background: #fff; color: #1c2333;\n        font: 13px/1.5 -apple-system, \"Segoe UI\", Roboto, sans-serif;\n    }\n    h2 { font-size: 14px; margin: 0 0 10px; }\n    section#kpis { display: flex; gap: 10px; }\n    section#kpis > div {\n        flex: 1; border: 1px solid #e3e7ef; border-radius: 8px; padding: 10px 12px;\n    }\n    .kpi-label { color: #6b7487; font-size: 11px; text-transform: uppercase; letter-spacing: .5px; }\n    .kpi-value { font-size: 19px; font-weight: 700; margin-top: 2px; }\n    .bars { display: flex; align-items: flex-end; gap: 5px; height: 70px; margin-top: 14px; }\n    .bars > span { flex: 1; background: #7ea2ff; border-radius: 3px 3px 0 0; }\n    .bars > span:nth-of-type(odd) { background: #3b6ff0; }\n    button#refresh-report {\n        margin-top: 12px; border: 1px solid #d7ddea; background: #f4f6fb;\n        border-radius: 6px; padding: 5px 12px; cursor: pointer; font: 600 12px -apple-system, sans-serif;\n    }\n</style>\n</head>\n<body>\n    <!-- CASE 6 targets: this document is loaded by <embedded-report>'s SHADOW iframe.\n         Expected: … > embedded-report >>> iframe#report ::document body > section#kpis > div:nth-of-type(1) -->\n    <h2>Week 28 — Traffic &amp; conversion</h2>\n    <section id=\"kpis\">\n        <div>\n            <div class=\"kpi-label\">Sessions</div>\n            <div class=\"kpi-value\">21,904</div>\n        </div>\n        <div>\n            <div class=\"kpi-label\">Signups</div>\n            <div class=\"kpi-value\">612</div>\n        </div>\n        <div>\n            <div class=\"kpi-label\">Conversion</div>\n            <div class=\"kpi-value\">2.8%</div>\n        </div>\n    </section>\n    <div class=\"bars\" aria-hidden=\"true\">\n        <span style=\"height:35%\"></span><span style=\"height:55%\"></span><span style=\"height:42%\"></span>\n        <span style=\"height:70%\"></span><span style=\"height:62%\"></span><span style=\"height:88%\"></span>\n        <span style=\"height:76%\"></span>\n    </div>\n    <button id=\"refresh-report\">Refresh</button>\n    <script>\n        document.getElementById('refresh-report').addEventListener('click', (e) => {\n            e.target.textContent = 'Refreshing…';\n            setTimeout(() => e.target.textContent = 'Refresh', 900);\n        });\n    </script>\n</body>\n</html>\n",
            "encoding": null
          }
        },
