            "last-modified": "Sun, 12 Jul 2026 14:01:04 GMT"
          },
          "content": {
            "size": 1783,
            "mimeType": "text/css",
            "text": "#query-tests #query-summary {\n    margin-bottom: 12px;\n    padding: 10px 12px;\n    border-radius: 7px;\n    background: #eef1f7;\n    font-weight: 700;\n}\n\n#query-tests #query-summary.running { color: #3b6ff0; }\n#query-tests #query-summary.passed { color: #2e9e5b; background: #e5f6ec; }\n#query-tests #query-summary.failed { color: #b42318; background: #fee4e2; }\n#query-results { display: grid; gap: 5px; margin: 0; padding: 0; list-style: none; }\n#query-results li {\n    display: grid;\n    grid-template-columns: 44px 1fr auto;\n    gap: 10px;\n    align-items: baseline;\n    padding: 7px 9px;\n    border: 1px solid #e3e7ef;\n    border-radius: 6px;\n}\n#query-results b { font-size: 10px; letter-spacing: .06em; }\n#query-results .pass b { color: #2e9e5b; }\n#query-results .fail b, #query-results .fail em { color: #b42318; }\n#query-results span > strong { display: block; color: #1c2333; font-weight: 700; }\n#query-results small { color: #6b7487; }\n#query-results code {\n    display: block;\n    margin-top: 2px;\n    color: #526078;\n    font: 11px/1.4 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;\n    overflow-wrap: anywhere;\n}\n#query-results mark {\n    border-radius: 3px;\n    padding: 0 3px;\n    font: inherit;\n    font-weight: 800;\n}\n#query-results .shadow-operator { color: #6941c6; background: #f4ebff; }\n#query-results .document-operator { color: #026aa2; background: #e0f2fe; }\n#query-results em { grid-column: 2 / -1; font-size: 12px; font-style: normal; }\n",
            "encoding": null
          }
        },
